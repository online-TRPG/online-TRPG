# 이 파일은 템플릿. 실제 사용 시 아래 세 개 파일을 레포 루트에 만든 뒤 값을 채우고,
# 각 실제 파일은 .gitignore 로 제외되어야 한다.
#
#   1) .env             — docker-compose 의 ${VAR} 치환용
#   2) .env.backend     — NestJS 백엔드 런타임 env
#   3) .env.ai          — FastAPI AI 서버 런타임 env


# =============================================================
# [.env] — docker-compose interpolation
# =============================================================
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=your_db_name
REDIS_PASSWORD=your_redis_password


# =============================================================
# [.env.backend] — NestJS backend runtime
# =============================================================
NODE_ENV=production
PORT=8080

DB_HOST=postgres
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_strong_password
DB_NAME=your_db_name

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

JWT_SECRET=generate_random_32bytes
JWT_EXPIRES_IN=1d

AI_SERVICE_URL=http://ai-server:8000


# JWT (현재 미설정 시 "dev-only-jwt-secret-change-me" 기본값 사용)
JWT_SECRET=랜덤_32바이트_이상_문자열

# Discord OAuth
DISCORD_CLIENT_ID=Discord_앱의_CLIENT_ID
DISCORD_CLIENT_SECRET=Discord_CLIENT_SECRET

# Kakao OAuth
KAKAO_REST_API_KEY=Kakao_앱의_REST_API_키
KAKAO_CLIENT_SECRET=카카오_CLIENT_SECRET



# =============================================================
# [.env.ai] — FastAPI AI server runtime
# =============================================================
APP_ENV=production
PORT=8000

LOG_LEVEL=INFO

# Google AI Studio (gemma-4-31b-it)
GOOGLE_API_KEY=your_google_api_key
AI_PROVIDER=google-ai-studio
AI_MODEL_DEFAULT=gemma-4-31b-it
AI_MODEL_INTERPRETER=gemma-4-31b-it
AI_MODEL_NARRATOR=gemma-4-31b-it
AI_TIMEOUT_MS=30000
AI_MAX_RETRIES=1
AI_TEMPERATURE_INTERPRETER=0.1
AI_TEMPERATURE_NARRATOR=0.4
AI_THINKING_LEVEL=high
