{
  "name": "@trpg/fe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:srd": "npm run --silent build -w @trpg/srd-data && node ../scripts/sync-fe-static-srd.mjs",
    "dev": "npm run --silent prepare:srd && vite --host 0.0.0.0 --port 5173 --strictPort",
    "build": "npm run --silent prepare:srd && tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@trpg/srd-data": "file:../srd-data",
    "@trpg/shared-types": "file:../shared-types",
    "konva": "^9.3.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.14",
    "react-router-dom": "^6.30.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.8.3",
    "vite": "^5.4.11"
  }
}
