{
  "name": "@trpg/srd-data",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs"
    },
    "./generated/srd/*": "./generated/srd/*",
    "./generated/srd-engine/*": "./generated/srd-engine/*"
  },
  "files": [
    "generated",
    "index.mjs",
    "index.d.ts",
    "overrides",
    "scripts",
    "sources"
  ],
  "scripts": {
    "build": "node scripts/generate-canonical-artifacts.mjs && node scripts/verify-generated.mjs",
    "import:spell-class-lists": "node scripts/import-spell-class-lists-from-dnd5eapi.mjs"
  }
}
