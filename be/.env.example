# Server
PORT=3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trpg?schema=public"

# AI Provider
# Default provider from the latest design docs.
AI_PROVIDER="google-ai-studio"
AI_TIMEOUT_MS=30000

# Google AI Studio / Gemini API
# Fill this only in your real .env, never commit the actual key.
GOOGLE_API_KEY=""
AI_MODEL_INTERPRETER="gemma-4-31b-it"
AI_MODEL_NARRATOR="gemma-4-31b-it"
AI_MODEL_ACTOR="gemma-4-31b-it"
AI_MODEL_DIRECTOR="gemma-4-31b-it"
AI_MODEL_SUMMARIZER="gemma-4-31b-it"


# JWT (현재 미설정 시 "dev-only-jwt-secret-change-me" 기본값 사용)
JWT_SECRET=랜덤_32바이트_이상_문자열

# Discord OAuth
DISCORD_CLIENT_ID=Discord_앱의_CLIENT_ID
DISCORD_CLIENT_SECRET=Discord_CLIENT_SECRET

# Kakao OAuth
KAKAO_REST_API_KEY=Kakao_앱의_REST_API_키
KAKAO_CLIENT_SECRET=카카오_CLIENT_SECRET
