generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  RECRUITING
  PLAYING
  PAUSED
  COMPLETED
  DISBANDED
}

enum SessionVisibility {
  PUBLIC
  PRIVATE
}

enum SessionScenarioStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ABANDONED
}

enum ParticipantRole {
  HOST
  PLAYER
  SPECTATOR
}

enum ParticipantStatus {
  JOINED
  LEFT
  KICKED
}

enum ConnectionStatus {
  ONLINE
  OFFLINE
}

enum GamePhase {
  LOBBY
  EXPLORATION
  COMBAT
  DIALOGUE
  REST
}

enum AuthProvider {
  LOCAL
  KAKAO
  DISCORD
  GUEST
}

enum GmMode {
  AI
  HUMAN
}

enum ScenarioLicense {
  ORIGINAL
  CC_BY_4_0
  OTHER_FREE
}

enum SessionCharacterStatus {
  ACTIVE
  RETIRED
  DEAD
  LEFT
}

enum CharacterAvatarType {
  DEFAULT
  PRESET
  UPLOAD
}

model User {
  id                     String               @id @default(cuid())
  displayName            String
  email                  String?              @unique
  passwordHash           String?
  authProvider           AuthProvider         @default(GUEST)
  deletedAt              DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @default(now()) @updatedAt
  hostedSessions         Session[]            @relation("SessionHost")
  participants           SessionParticipant[]
  characters             Character[]
  refreshTokens          RefreshToken[]
  socialAccounts         SocialAccount[]
  controlledCharacters   SessionCharacter[]
}

model Session {
  id               String               @id @default(cuid())
  title            String
  description      String               @default("")
  hostUserId       String
  inviteCode       String               @unique
  status           SessionStatus        @default(RECRUITING)
  visibility       SessionVisibility    @default(PUBLIC)
  maxParticipants  Int                  @default(4)
  ruleSetId        String?
  gmMode           GmMode               @default(AI)
  nextSessionAt    DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  host             User                 @relation("SessionHost", fields: [hostUserId], references: [id])
  participants     SessionParticipant[]
  sessionScenarios SessionScenario[]
  sessionCharacters SessionCharacter[]
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SocialAccount {
  id             String       @id @default(cuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  email          String?
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
}

model SessionParticipant {
  id               String             @id @default(cuid())
  sessionId        String
  userId           String
  role             ParticipantRole    @default(PLAYER)
  status           ParticipantStatus  @default(JOINED)
  connectionStatus ConnectionStatus   @default(ONLINE)
  isReady          Boolean            @default(false)
  readyAt          DateTime?
  joinedAt         DateTime           @default(now())
  leftAt           DateTime?
  session          Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionCharacter SessionCharacter?  @relation("ParticipantSessionCharacter")

  @@unique([sessionId, userId])
}

model Character {
  id                   String               @id @default(cuid())
  ownerUserId          String
  name                 String
  ancestry             String
  className            String
  level                Int
  bio                  String?
  abilitiesJson        String
  proficiencyBonus     Int
  proficientSkillsJson String
  maxHp                Int
  armorClass           Int
  speed                Int
  inventoryJson        String
  equippedWeaponId     String?
  avatarType           CharacterAvatarType  @default(DEFAULT)
  avatarPresetId       String?
  avatarUrl            String?
  avatarUpdatedAt      DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  owner                User                 @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  sessionCharacters    SessionCharacter[]
}

model SessionCharacter {
  id                    String                  @id @default(cuid())
  sessionId             String
  userId                String
  characterId           String
  status                SessionCharacterStatus  @default(ACTIVE)
  currentHp             Int
  tempHp                Int
  conditionsJson        String
  inventorySnapshotJson String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  session               Session                 @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant           SessionParticipant      @relation("ParticipantSessionCharacter", fields: [sessionId, userId], references: [sessionId, userId], onDelete: Cascade)
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  character             Character               @relation(fields: [characterId], references: [id])

  @@unique([sessionId, userId])
  @@unique([sessionId, characterId])
}

model Scenario {
  id           String            @id
  title        String
  description  String?
  thumbnailUrl String?
  ruleSetId    String?
  difficulty   String?
  license      ScenarioLicense
  attribution  String?
  startNodeId  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  nodes        ScenarioNode[]
  sessions     SessionScenario[]
}

model ScenarioNode {
  id               String   @id
  scenarioId       String
  title            String
  sceneText        String
  visibleToPlayers Boolean  @default(true)
  checkOptionsJson String
  transitionsJson  String
  cluesJson        String
  fallbackNodeId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  scenario         Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}

model SessionScenario {
  id         String                @id @default(cuid())
  sessionId  String
  scenarioId String
  sequence   Int
  status     SessionScenarioStatus @default(PLANNED)
  startedAt  DateTime?
  endedAt    DateTime?
  createdAt  DateTime              @default(now())
  session    Session               @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scenario   Scenario              @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  gameState  GameState?

  @@unique([sessionId, sequence])
}

model GameState {
  sessionScenarioId   String    @id
  version             Int       @default(1)
  currentNodeId       String?
  phase               GamePhase @default(LOBBY)
  flagsJson           String?
  discoveredCluesJson String?
  updatedAt           DateTime  @updatedAt
  sessionScenario     SessionScenario @relation(fields: [sessionScenarioId], references: [id], onDelete: Cascade)
}
