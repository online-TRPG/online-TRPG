generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  LOBBY
  PLAYING
  PAUSED
  COMPLETED
}

enum SessionGmMode {
  AI
  HUMAN
}

enum ParticipantRole {
  HOST
  PLAYER
  SPECTATOR
}

enum ConnectionStatus {
  ONLINE
  OFFLINE
}

enum GamePhase {
  EXPLORATION
  COMBAT
  DIALOGUE
  REST
}

enum ScenarioLicense {
  ORIGINAL
  CC_BY_4_0
  OTHER_FREE
}

model User {
  id            String               @id @default(cuid())
  displayName   String
  createdAt     DateTime             @default(now())
  ownedSessions Session[]            @relation("SessionOwner")
  participants  SessionParticipant[]
  characters    Character[]
}

model Session {
  id               String               @id @default(cuid())
  title            String
  description      String               @default("")
  ownerUserId      String
  captainUserId    String?
  inviteCode       String               @unique
  gmMode           SessionGmMode        @default(AI)
  status           SessionStatus        @default(LOBBY)
  maxParticipants  Int                  @default(4)
  isPublic         Boolean              @default(true)
  scenarioId       String
  currentNodeId    String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  owner            User                 @relation("SessionOwner", fields: [ownerUserId], references: [id])
  scenario         Scenario             @relation(fields: [scenarioId], references: [id])
  participants     SessionParticipant[]
  sessionCharacters SessionCharacter[]
  gameState        GameState?
}

model SessionParticipant {
  id               String           @id @default(cuid())
  sessionId        String
  userId           String
  role             ParticipantRole  @default(PLAYER)
  connectionStatus ConnectionStatus @default(ONLINE)
  joinedAt         DateTime         @default(now())
  session          Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionCharacter SessionCharacter?

  @@unique([sessionId, userId])
}

model Character {
  id                   String             @id @default(cuid())
  ownerUserId          String
  name                 String
  ancestry             String
  className            String
  level                Int
  abilitiesJson        String
  proficiencyBonus     Int
  proficientSkillsJson String
  maxHp                Int
  armorClass           Int
  speed                Int
  inventoryJson        String
  equippedWeaponId     String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  owner                User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  sessionCharacters    SessionCharacter[]
}

model SessionCharacter {
  id                   String             @id @default(cuid())
  sessionId            String
  participantId        String             @unique
  characterId          String
  name                 String
  ancestry             String
  className            String
  level                Int
  abilitiesJson        String
  proficiencyBonus     Int
  proficientSkillsJson String
  maxHp                Int
  currentHp            Int
  tempHp               Int
  armorClass           Int
  speed                Int
  inventoryJson        String
  equippedWeaponId     String?
  conditionsJson       String
  initiative           Int?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  session              Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant          SessionParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  character            Character          @relation(fields: [characterId], references: [id])

  @@unique([sessionId, characterId])
}

model Scenario {
  id          String            @id
  title       String
  license     ScenarioLicense
  attribution String
  startNodeId String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  nodes       ScenarioNode[]
  sessions    Session[]
}

model ScenarioNode {
  id               String   @id
  scenarioId       String
  title            String
  sceneText        String
  visibleToPlayers Boolean  @default(true)
  checkOptionsJson String
  transitionsJson  String
  cluesJson        String
  fallbackNodeId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  scenario         Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}

model GameState {
  sessionId     String    @id
  version       Int       @default(1)
  currentNodeId String
  phase         GamePhase @default(EXPLORATION)
  stateJson     String
  updatedAt     DateTime  @updatedAt
  session       Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
